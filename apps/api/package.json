{
  "name": "@ticker-lab/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:unit": "vitest run --dir src/domain src/application",
    "test:functional": "vitest run --dir src/infrastructure",
    "lint": "biome check .",
    "format": "biome check --fix .",
    "typecheck": "tsc --noEmit",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "openapi:generate": "openapi-typescript openapi.yaml -o ../packages/shared/src/generated/api.ts",
    "job:ingest": "tsx src/infrastructure/jobs/ingest.ts",
    "job:backfill": "tsx src/infrastructure/jobs/backfill.ts"
  },
  "dependencies": {
    "@fastify/view": "^10.0.0",
    "drizzle-orm": "^0.40.0",
    "eta": "^3.5.0",
    "fastify": "^5.2.0",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.30.0",
    "openapi-typescript": "^7.6.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
